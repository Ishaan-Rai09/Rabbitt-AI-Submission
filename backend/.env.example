# Environment variables for FireReach backend
# Copy this file to .env and fill in your values

# --- Required ---
# Get your free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# --- Email Sending (Gmail SMTP with App Password) ---
# Use a Google App Password — NOT your regular Gmail password.
# 1. Enable 2-Step Verification on your Google account
# 2. Visit https://myaccount.google.com/apppasswords
# 3. Create an App Password for "Mail" and paste it below
SMTP_EMAIL=your_gmail_address@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here

# --- Signal Harvesting (optional but recommended) ---
# Get a free key at https://newsapi.org/register
NEWSAPI_KEY=your_newsapi_key_here
